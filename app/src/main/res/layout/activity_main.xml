<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="MergeRootFrame">

    <com.clockin.assistant.ui.MoodBackgroundView
        android:id="@+id/mood_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="@dimen/page_padding"
            android:paddingTop="20dp"
            android:paddingRight="@dimen/page_padding"
            android:paddingBottom="38dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/text_greeting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="3"
                        android:text="@string/greeting_morning"
                        android:textColor="@color/ink"
                        android:textSize="@dimen/greeting_text_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_header_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="@string/header_ready"
                        android:textColor="@color/ink_muted"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.clockin.assistant.ui.GlowToggleView
                    android:id="@+id/switch_enabled"
                    android:layout_width="@dimen/toggle_width"
                    android:layout_height="@dimen/toggle_height"
                    android:contentDescription="@string/running" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_mood_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_mood_badge"
                android:textColor="@color/ink"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_schedule_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="@string/schedule_title"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_schedule_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/schedule_subtitle"
                android:textColor="@color/ink_muted"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/shift_card_height"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/card_morning"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_shift_morning"
                    android:clickable="true"
                    android:elevation="8dp"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/shift_card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/morning_emoji"
                        android:textSize="@dimen/shift_emoji_size" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/morning_card_title"
                        android:textColor="@color/ink"
                        android:textSize="@dimen/shift_title_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_morning_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:text="@string/default_morning_time"
                        android:textColor="@color/ink"
                        android:textSize="@dimen/shift_time_size"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/morning_card_hint"
                        android:textColor="#B33E4B45"
                        android:textSize="@dimen/shift_hint_size" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_evening"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_shift_evening"
                    android:clickable="true"
                    android:elevation="8dp"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/shift_card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/evening_emoji"
                        android:textSize="@dimen/shift_emoji_size" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/evening_card_title"
                        android:textColor="@color/white"
                        android:textSize="@dimen/shift_title_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_evening_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="monospace"
                        android:gravity="center"
                        android:text="@string/default_evening_time"
                        android:textColor="@color/white"
                        android:textSize="@dimen/shift_time_size"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/evening_card_hint"
                        android:textColor="#CFFFFFFF"
                        android:textSize="@dimen/shift_hint_size" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_glass_card"
                android:elevation="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/frequency_title"
                    android:textColor="@color/ink_muted"
                    android:textSize="@dimen/frequency_label_size"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/radio_frequency"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radio_daily"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_frequency_selector"
                        android:button="@null"
                        android:checked="true"
                        android:gravity="center"
                        android:text="@string/every_day"
                        android:textColor="@color/ink"
                        android:textSize="@dimen/frequency_option_size"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/radio_weekdays"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_frequency_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:text="@string/weekdays_only"
                        android:textColor="@color/ink"
                        android:textSize="@dimen/frequency_option_size"
                        android:textStyle="bold" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_future_pod"
                android:elevation="12dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:text="@string/next_run_title"
                    android:textColor="@color/neon_green"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_next_run"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/pod_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_countdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/pod_muted"
                    android:textSize="12sp" />

                <com.clockin.assistant.ui.ShiftProgressView
                    android:id="@+id/shift_progress"
                    android:layout_width="match_parent"
                    android:layout_height="9dp"
                    android:layout_marginTop="14dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="15dp"
                    android:background="@color/divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/last_trigger_title"
                    android:textColor="@color/pod_muted"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/text_last_trigger"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/no_trigger_record"
                    android:textColor="@color/pod_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/button_test"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_neon_button"
                android:elevation="12dp"
                android:text="@string/test_open"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_screen_off_test"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="9dp"
                android:background="@drawable/bg_glass_button"
                android:elevation="5dp"
                android:text="@string/screen_off_test"
                android:textAllCaps="false"
                android:textColor="@color/ink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_health_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/setup_title"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_health_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/setup_dashboard_hint"
                android:textColor="@color/ink_muted"
                android:textSize="12sp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <include
                    android:id="@+id/status_wecom"
                    layout="@layout/view_status_row"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/status_tile_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include
                    android:id="@+id/status_accessibility"
                    layout="@layout/view_status_row"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/status_tile_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include
                    android:id="@+id/status_exact"
                    layout="@layout/view_status_row"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/status_tile_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include
                    android:id="@+id/status_notification"
                    layout="@layout/view_status_row"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/status_tile_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include
                    android:id="@+id/status_full_screen"
                    layout="@layout/view_status_row"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/status_tile_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />

                <include
                    android:id="@+id/status_battery"
                    layout="@layout/view_status_row"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/status_tile_height"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp" />
            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_glass_card"
                android:elevation="5dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/text_device_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/ink"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/button_device_settings"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_xiaomi_capsule"
                    android:textAllCaps="false"
                    android:textColor="@color/ink"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_setup_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/setup_hint"
                android:textColor="@color/ink_muted"
                android:textSize="11sp" />

            <Button
                android:id="@+id/button_manual"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_glass_button"
                android:text="@string/manual_entry"
                android:textAllCaps="false"
                android:textColor="@color/ink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_future_pod"
                android:elevation="9dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:text="@string/update_title"
                    android:textColor="@color/neon_green"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_update_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/pod_text"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/button_check_update"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="13dp"
                    android:background="@drawable/bg_neon_button"
                    android:text="@string/check_update"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
