<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_trigger"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:padding="18dp"
    android:scrollbars="none">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foregroundGravity="center"
        tools:ignore="UselessParent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_trigger_card"
            android:elevation="14dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:text="@string/secure_relay"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_marginTop="16dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_launcher" />

            <TextView
                android:id="@+id/text_trigger_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/opening_wecom"
                android:textColor="@color/ink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_trigger_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/ink_muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/button_trigger_retry"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_neon_button"
                android:text="@string/unlock_and_open"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/button_trigger_close"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="9dp"
                android:background="@drawable/bg_glass_button"
                android:text="@string/close"
                android:textAllCaps="false"
                android:textColor="@color/ink"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>
</ScrollView>
