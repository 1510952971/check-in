<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <shape>
            <gradient
                android:angle="0"
                android:startColor="#EFFF9F1C"
                android:endColor="#EFFF5C67" />
            <stroke
                android:width="1dp"
                android:color="#E6FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#7FFFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#68FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</selector>
