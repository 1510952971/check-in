<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#E5FFE89B"
                android:endColor="#D6FFB24A" />
            <stroke
                android:width="1dp"
                android:color="#D9FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="315"
                android:startColor="#CFFFF3B0"
                android:centerColor="#C8FFD68A"
                android:endColor="#B8A8E8AE" />
            <stroke
                android:width="1dp"
                android:color="#BFFFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
